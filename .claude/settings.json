{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/legacy-cli-pretool.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/clang-format-postedit.sh\"",
            "timeout": 30,
            "statusMessage": "Running clang-format on edited C++ file"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/clang-tidy-postedit.sh\"",
            "timeout": 60,
            "statusMessage": "Running clang-tidy on edited C++ file"
          }
        ]
      }
    ]
  }
}
